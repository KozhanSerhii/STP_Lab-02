# Перший рядок у докер-файлі визначає базове зображення для використання. Цей образ 
# містить час виконання для запуску та зберігання файлів.
# У нашому випадку ми будемо використовувати полегшену версію Linux під назвою Alpine Linux.
FROM alpine:3.14

# Команда WORKDIR вказує каталог у контейнері, де зберігаються файли.
WORKDIR /my-app

# За допомогою RUN ми можемо виконати команду (shell) в контейнері.
# У наступному рядку ми створюємо файл з назвою 'who.who'
RUN touch who.who

# У цьому рядку ми запускаємо скрипт і зберігаємо результати в раніше створеному файлі.
RUN echo "Hello there $(whoami)" > who.who

# Наостанок запустимо CMD-команду докера. Вона використовується для виконання програми у
# контейнері. Виконується останньою командою.
# У нашому випадку ми хочемо відобразити вміст нашого раніше створеного файлу.
CMD [ "cat", "who.who" ]
